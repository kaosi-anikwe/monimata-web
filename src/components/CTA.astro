---

<section id="cta" class="relative w-full bg-bg">
  <!-- Styled background strip -->
  <div class="absolute inset-x-0 bottom-0 h-64 sm:h-80 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-t from-primary-dark/80 via-primary-dark/40 to-transparent"></div>
    <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Ccircle%20cx%3D%2230%22%20cy%3D%2230%22%20r%3D%221.5%22%20fill%3D%22%230c251f%22%20fill-opacity%3D%220.15%22%2F%3E%3C%2Fsvg%3E')] opacity-50"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 sm:py-20">
    <div class="relative bg-primary-dark rounded-3xl overflow-hidden p-8 sm:p-12 lg:p-16 text-center text-white">
      <!-- Decorative blurs -->
      <div class="absolute -top-20 -left-20 w-72 h-72 rounded-full bg-cta-green/30 blur-3xl" aria-hidden="true"></div>
      <div class="absolute -bottom-20 -right-10 w-72 h-72 rounded-full bg-primary-dark/60 blur-3xl" aria-hidden="true"></div>
      <div class="absolute top-10 right-10 w-40 h-40 rounded-full bg-accent/10 blur-2xl" aria-hidden="true"></div>

      <div class="relative max-w-2xl mx-auto">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-semibold leading-tight">
          Ready to make every<br />Naira count?
        </h2>
        <p class="mt-5 text-base sm:text-lg opacity-90">
          Be the first to know when MoniMata launches. Join the waitlist and start giving every naira a job.
        </p>
        <a href="#" class="inline-block mt-8 bg-accent text-black rounded-xl px-6 py-3 text-sm font-medium hover:opacity-90">
          Join Waitlist
        </a>
      </div>
    </div>
  </div>
</section>
