};

import { Image } from "astro:assets";
import featurePhone from "../assets/images/feature-phone.png";
---

<section id="features" class="w-full bg-bg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 sm:py-20">
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-14">
      <h2
        class="text-text-heading text-3xl sm:text-4xl lg:text-[40px] font-semibold"
      >
        Built for real Nigerian life
      </h2>
      <p class="mt-4 text-text-body text-base sm:text-lg lg:text-xl">
        Every feature was designed around how Nigerians actually spend, save,
        and pay bills.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {
        features.map((f) => (
          <article class="bg-white rounded-3xl overflow-hidden flex flex-col shadow-sm">
            <div class="p-6 flex flex-col gap-3 flex-1">
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center"
                style={`background:${f.iconBg}`}
              >
                <svg
                  class="w-6 h-6"
                  style={`color:${f.accent}`}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  set:html={icons[f.title]}
                />
              </div>
              <h3 class="text-text-heading text-lg font-bold">{f.title}</h3>
              <p class="text-text-subtle text-sm leading-relaxed">{f.desc}</p>
            </div>
            <div class="relative bg-bg-subtle mt-auto p-6 flex justify-center min-h-55 overflow-hidden">
              <Image
                src={featurePhone}
                alt="MoniMata app feature preview on iPhone"
                class="w-32 sm:w-36 object-contain object-top"
              />
              <div class="absolute top-6 left-6 bg-white rounded-lg px-2 py-1.5 flex items-center gap-1.5 shadow">
                <svg
                  class="w-3.5 h-3.5"
                  style={`color:${f.accent}`}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <div class="leading-none">
                  <div class="uppercase text-[5px] font-semibold text-accent-light">
                    Daily Tracking
                  </div>
                  <div class="text-[8px] font-bold text-black mt-0.5">
                    Daily Limit Reached
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
