---
const features = [
  {
    title: "Zero-Based Budgeting",
    desc: "Every naira gets a job. Assign income to categories like food, transport, and rent — nothing left unaccounted for.",
    iconBg: "var(--color-card-purple)",
    accent: "var(--color-feature-magenta)",
  },
  {
    title: "Smart Nudges in Pidgin",
    desc: "Get alerts like ‘Oga, you don spend too much on snacks o!’ — timely, culturally relevant nudges in Pidgin or English.",
    iconBg: "var(--color-card-lime)",
    accent: "var(--color-accent-lime)",
  },
  {
    title: "Bill Payments",
    desc: "Pay airtime, data, electricity, and cable TV directly from the app via Interswitch Quickteller integration.",
    iconBg: "var(--color-card-pink)",
    accent: "var(--color-feature-coral)",
  },
  {
    title: "Mono Bank Sync",
    desc: "Connect your bank account via Mono to auto-import transactions and keep your budget always up to date.",
    iconBg: "var(--color-card-lime)",
    accent: "var(--color-accent-lime)",
  },
  {
    title: "Savings Targets & Goals",
    desc: "Set goals like ‘New Phone’ or ‘Emergency Fund’ with visual progress tracking. Celebrate when you hit targets.",
    iconBg: "var(--color-card-purple)",
    accent: "var(--color-feature-magenta)",
  },
  {
    title: "Offline-First Storage",
    desc: "Built on WatermelonDB — works without internet. Your data syncs automatically when you’re back online.",
    iconBg: "var(--color-card-pink)",
    accent: "var(--color-feature-coral)",
  },
];

const icons: Record<string, string> = {
  "Zero-Based Budgeting": `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>`,
  "Smart Nudges in Pidgin": `<path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/>`,
  "Bill Payments": `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z"/>`,
  "Mono Bank Sync": `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/>`,
  "Savings Targets & Goals": `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  "Offline-First Storage": `<path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125"/>`,
};

import { Image } from "astro:assets";
import featurePhone from "../assets/images/feature-phone.png";
---

<section id="features" class="w-full bg-bg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 sm:py-20">
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-14">
      <h2
        class="text-text-heading text-3xl sm:text-4xl lg:text-[40px] font-semibold"
      >
        Built for real Nigerian life
      </h2>
      <p class="mt-4 text-text-body text-base sm:text-lg lg:text-xl">
        Every feature was designed around how Nigerians actually spend, save,
        and pay bills.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {
        features.map((f) => (
          <article class="bg-white rounded-3xl overflow-hidden flex flex-col shadow-sm">
            <div class="p-6 flex flex-col gap-3 flex-1">
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center"
                style={`background:${f.iconBg}`}
              >
                <svg
                  class="w-6 h-6"
                  style={`color:${f.accent}`}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  set:html={icons[f.title]}
                />
              </div>
              <h3 class="text-text-heading text-lg font-bold">{f.title}</h3>
              <p class="text-text-subtle text-sm leading-relaxed">{f.desc}</p>
            </div>
            <div class="relative bg-bg-subtle mt-auto p-6 flex justify-center min-h-55 overflow-hidden">
              <Image
                src={featurePhone}
                alt="MoniMata app feature preview on iPhone"
                class="w-32 sm:w-36 object-contain object-top"
              />
              <div class="absolute top-6 left-6 bg-white rounded-lg px-2 py-1.5 flex items-center gap-1.5 shadow">
                <svg
                  class="w-3.5 h-3.5"
                  style={`color:${f.accent}`}
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <div class="leading-none">
                  <div class="uppercase text-[5px] font-semibold text-accent-light">
                    Daily Tracking
                  </div>
                  <div class="text-[8px] font-bold text-black mt-0.5">
                    Daily Limit Reached
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
