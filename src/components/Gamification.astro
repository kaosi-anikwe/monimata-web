---
const chips = [
  { label: "Recurring Transactions", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.653v4.992"/>` },
  { label: "5 Auto-Assign Modes", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"/>` },
  { label: "Biometric Lock", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M7.864 4.243A7.5 7.5 0 0119.5 10.5c0 2.92-.556 5.709-1.568 8.268M5.742 6.364A7.465 7.465 0 004.5 10.5a48.667 48.667 0 00-1.488 8.01M10.5 2.25a7.5 7.5 0 017.5 7.5c0 .61-.018 1.214-.053 1.813M12.75 10.5a2.25 2.25 0 10-4.5 0 2.25 2.25 0 004.5 0z"/>` },
  { label: "Pidgin & English", icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 21l5.25-11.25L21 21m-9-3h7.5M3 5.621a48.474 48.474 0 016-.371m0 0c1.12 0 2.233.038 3.334.114M9 5.25V3M12.334 5.364C18.335 5.88 21 8.75 21 12c0 .778-.088 1.536-.255 2.262"/>` },
];
---

<section id="screenshots" class="w-full bg-bg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 sm:py-20">
    <div class="relative bg-primary-darker rounded-3xl overflow-hidden p-6 sm:p-10 lg:p-14">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <div class="text-white">
          <div class="uppercase text-accent-lime text-sm font-semibold tracking-wide">Built Different</div>
          <h2 class="mt-3 text-3xl sm:text-4xl lg:text-[40px] font-semibold leading-tight">
            <span class="text-accent-lime">Make Every Naira </span>
            <span class="text-white">Count</span>
          </h2>
          <p class="mt-5 text-base sm:text-lg lg:text-xl opacity-90 max-w-xl">
            MoniMata goes beyond tracking. Recurring transactions, 5 auto-assign strategies, biometric security, and Pidgin/English support make it the most Nigerian budgeting app ever built.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {chips.map(({ icon, label }) => (
              <span class="inline-flex items-center gap-2 bg-gamification-pill text-black rounded-full px-4 py-2 text-sm sm:text-base">
                <svg class="w-4.5 h-4.5 text-accent-lime" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={icon} />
                {label}
              </span>
            ))}
          </div>
        </div>

        <div class="relative flex justify-center items-center">
          <img src="/images/gamification-phone.png" alt="" class="w-56 sm:w-64 lg:w-72 object-contain z-10" />
        </div>
      </div>
    </div>
  </div>
</section>
