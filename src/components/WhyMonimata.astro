---
import { Image } from "astro:assets";
import whyFrame1 from "../assets/images/why-frame1.png";
import whyFrame2 from "../assets/images/why-frame2.png";
import whyFrame3 from "../assets/images/why-frame3.png";
---

<section id="why" class="w-full bg-bg">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-16 sm:py-20">
    <!-- Header -->
    <div class="grid lg:grid-cols-2 gap-10 items-center mb-12">
      <div
        class="bg-primary-darker rounded-3xl overflow-hidden aspect-4/3 flex items-center justify-center"
      >
        <img
          src="/images/logo-full-dark.svg"
          alt="MoniMata"
          class="w-2/3 max-w-sm object-contain"
        />
      </div>
      <div>
        <h2
          class="text-primary-darker text-3xl sm:text-4xl lg:text-[36px] font-medium leading-tight"
        >
          Why MoniMata
        </h2>
        <p class="mt-5 text-primary-darker text-base leading-relaxed">
          Most budgeting apps weren't built for Nigerians. MoniMata is —
          naira-native, Pidgin nudges, zero-based budgeting, and automatic
          transaction capture from your bank alert emails. Fully open-source and
          works offline too.
        </p>
      </div>
    </div>

    <!-- Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      <!-- Card 1 — large, image with stat -->
      <article
        class="lg:col-span-2 lg:row-span-2 relative rounded-3xl overflow-hidden min-h-105 flex flex-col justify-between p-6 sm:p-8 text-white"
      >
        <Image
          src={whyFrame1}
          alt=""
          role="presentation"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="relative">
          <span
            class="inline-flex items-center gap-1.5 bg-primary-dark text-white rounded-full px-3 py-1.5 text-xs sm:text-sm font-semibold"
          >
            <svg
              class="w-3.5 h-3.5 fill-accent-light text-accent-light"
              viewBox="0 0 24 24"
              ><polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon></svg
            >
            For Nigerians
          </span>
        </div>
        <div class="relative">
          <div class="flex items-baseline gap-3 flex-wrap">
            <span
              class="text-5xl sm:text-6xl lg:text-[64px] font-bold leading-none"
              >₦0</span
            >
            <span class="text-xl sm:text-2xl text-accent-light">Unassigned</span
            >
          </div>
          <p class="mt-4 text-lg sm:text-xl lg:text-2xl">
            Zero-based budgeting that assigns every naira to a category before
            you spend
          </p>
        </div>
      </article>

      <!-- Card 2 -->
      <article
        class="relative rounded-3xl overflow-hidden min-h-65 flex flex-col justify-between p-6 text-white"
      >
        <Image
          src={whyFrame2}
          alt=""
          role="presentation"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="relative">
          <span
            class="inline-flex items-center gap-1.5 bg-primary-dark text-white rounded-full px-3 py-1.5 text-xs sm:text-sm font-semibold"
          >
            <svg
              class="w-3.5 h-3.5 fill-accent-light text-accent-light"
              viewBox="0 0 24 24"
              ><polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon></svg
            >
            Privacy First
          </span>
        </div>
        <div class="relative">
          <div class="flex items-baseline gap-3 flex-wrap">
            <span class="text-lg">Zero credentials</span>
          </div>
          <p class="mt-3 text-lg">
            MoniMata reads forwarded bank alert emails. No login credentials, no
            API access — your bank never knows it exists.
          </p>
        </div>
      </article>

      <!-- Card 3 -->
      <article
        class="relative rounded-3xl overflow-hidden min-h-65 flex flex-col justify-between p-6 text-white"
      >
        <Image
          src={whyFrame3}
          alt=""
          role="presentation"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/20"></div>
        <div class="relative">
          <span
            class="inline-flex items-center gap-1.5 bg-primary-dark text-white rounded-full px-3 py-1.5 text-xs sm:text-sm font-semibold"
          >
            <svg
              class="w-3.5 h-3.5 fill-accent-light text-accent-light"
              viewBox="0 0 24 24"
              ><polygon
                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
              ></polygon></svg
            >
            Goal Planning
          </span>
        </div>
        <div class="relative">
          <p class="mt-3 text-lg">
            Set targets for rent, school fees, or emergencies — track progress
            and celebrate milestones.
          </p>
        </div>
      </article>

      <!-- Card 4 — green -->
      <article
        class="lg:col-span-2 bg-accent-light rounded-3xl min-h-50 flex flex-col justify-between p-6 sm:p-8"
      >
        <span
          class="inline-flex items-center gap-1.5 bg-primary-dark text-white rounded-full px-3 py-1.5 text-xs sm:text-sm font-semibold w-fit"
        >
          <svg
            class="w-3.5 h-3.5 fill-accent-light text-accent-light"
            viewBox="0 0 24 24"
            ><polygon
              points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
            ></polygon></svg
          >
          Expense Tracker
        </span>
        <p
          class="text-xl sm:text-2xl lg:text-[32px] lg:leading-snug font-light text-black"
        >
          AI auto-categorises transactions from bank alerts and receipts. You
          review and confirm — always in control.
        </p>
      </article>
    </div>
  </div>
</section>
