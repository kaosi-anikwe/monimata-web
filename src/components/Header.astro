---
import { getHeaderCategories } from "../lib/sanity";

const categories = await getHeaderCategories();
---

<header
  class="sticky top-0 z-50 w-full bg-bg/80 backdrop-blur-md border-b border-black/5"
>
  <nav
    class="mx-auto max-w-7xl flex items-center justify-between px-4 sm:px-6 lg:px-10 py-4"
  >
    <a href="/#" class="flex items-center">
      <img
        src="/images/logo-full.svg"
        alt="MoniMata"
        class="h-8 sm:h-10 w-auto"
      />
    </a>

    <ul
      class="hidden md:flex items-center gap-6 lg:gap-8 text-text-heading text-sm"
    >
      <li>
        <a href="/#features" class="hover:opacity-70 transition">Features</a>
      </li>
      <li>
        <a href="/#how-it-works" class="hover:opacity-70 transition"
          >How It Works</a
        >
      </li>
      <li>
        <a href="/#why" class="hover:opacity-70 transition">Clarity</a>
      </li>
      <li><a href="/#faqs" class="hover:opacity-70 transition">FAQs</a></li>
      {
        categories.map((cat: any) => (
          <li>
            <a href={`/${cat.slug}`} class="hover:opacity-70 transition">
              {cat.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="hidden md:block">
      <a
        href="/#cta"
        class="inline-flex items-center justify-center bg-primary-dark text-bg rounded-xl px-5 py-3 text-sm font-semibold hover:opacity-90 transition"
      >
        Join Waitlist
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      aria-label="Toggle menu"
      class="md:hidden p-2 text-primary-dark"
    >
      <svg
        id="menu-icon"
        class="w-6 h-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        id="close-icon"
        class="w-6 h-6 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-black/5 bg-bg">
    <ul class="flex flex-col px-4 py-4 gap-3 text-text-heading">
      <li><a href="/#features" class="mobile-nav-link block">Features</a></li>
      <li>
        <a href="/#how-it-works" class="mobile-nav-link block">How It Works</a>
      </li>
      <li>
        <a href="/#screenshots" class="mobile-nav-link block">Screenshots</a>
      </li>
      <li><a href="/#faqs" class="mobile-nav-link block">FAQs</a></li>
      {
        categories.map((cat: any) => (
          <li>
            <a href={`/${cat.slug}`} class="mobile-nav-link block">
              {cat.name}
            </a>
          </li>
        ))
      }
      <li>
        <a
          href="/#cta"
          class="mobile-nav-link block text-center bg-primary-dark text-bg rounded-xl px-5 py-3 text-sm font-semibold mt-2"
          >Join Waitlist</a
        >
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  btn?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });

  document.querySelectorAll(".mobile-nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    });
  });
</script>
