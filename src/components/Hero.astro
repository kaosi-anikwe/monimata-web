---
import { Image } from "astro:assets";
import heroPhone from "../assets/images/hero-hand-phone.png";
import avatar1 from "../assets/images/avatar1.png";
import avatar2 from "../assets/images/avatar2.png";
import avatar3 from "../assets/images/avatar3.png";
---

<section class="relative w-full bg-bg overflow-hidden">
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 pt-4 sm:pt-6 pb-0 text-center"
  >
    <h1
      class="text-primary-dark font-bold leading-tight text-2xl sm:text-3xl lg:text-4xl"
    >
      Give Every <span class="relative inline-block text-accent"
        >Kobo<svg
          class="absolute -bottom-1 left-0 w-full"
          height="6"
          viewBox="0 0 200 10"
          fill="none"
          preserveAspectRatio="none"
        >
          <path
            d="M2 7 C 50 1, 150 1, 198 7"
            stroke="var(--color-accent)"
            stroke-width="3"
            stroke-linecap="round"
            fill="none"></path>
        </svg></span
      > a Job.
    </h1>
    <p class="mt-2 mx-auto max-w-lg text-text-body text-xs sm:text-sm">
      The open-source budgeting app built for Nigeria. Know exactly where your
      money goes — transactions captured automatically from bank alert emails,
      with offline budgeting that works even without data.
    </p>

    <div
      class="relative mt-4 lg:mt-6 mx-auto"
      style="max-width:960px;height:calc(100vh - 220px);min-height:400px;"
    >
      <!-- Concentric rings -->
      <div
        class="absolute inset-0 flex items-center justify-center pointer-events-none"
        aria-hidden="true"
      >
        <div
          class="absolute rounded-full border border-text-heading/8"
          style="width:320px;height:320px;"
        >
        </div>
        <div
          class="absolute rounded-full border border-text-heading/6"
          style="width:480px;height:480px;"
        >
        </div>
        <div
          class="absolute rounded-full border border-text-heading/5"
          style="width:640px;height:640px;"
        >
        </div>
        <div
          class="absolute rounded-full border border-text-heading/4"
          style="width:800px;height:800px;"
        >
        </div>
      </div>

      <!-- Phone image — background-style, overflows container -->
      <div class="absolute inset-0 flex justify-center pointer-events-none">
        <Image
          src={heroPhone}
          alt="Hand holding iPhone showing MoniMata app"
          class="relative z-10 w-auto max-w-none object-contain object-top"
          style="height: 115%;"
        />
      </div>

      <!-- Yellow card — top left -->
      <div
        class="hidden sm:flex absolute top-[10%] left-0 lg:-left-4 w-36 lg:w-44 p-3 bg-card-yellow rounded-2xl flex-col gap-1.5 shadow-sm z-20"
      >
        <svg
          class="w-5 h-5 text-text-dark"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M8 21h8m-4-4v4m-4.5-9.5a4.5 4.5 0 019 0V8a2 2 0 00-2-2H9.5a2 2 0 00-2 2v3.5zM6 8H4a1 1 0 00-1 1v2a3 3 0 003 3h.5M18 8h2a1 1 0 011 1v2a3 3 0 01-3 3h-.5"
          ></path>
        </svg>
        <p class="text-text-dark text-[11px] lg:text-xs">
          Zero-based budgeting — assign every naira before you spend it.
        </p>
      </div>

      <!-- Coral card — bottom left -->
      <div
        class="hidden sm:flex absolute bottom-[10%] left-[2%] lg:left-0 w-36 lg:w-44 p-3 bg-card-coral rounded-2xl flex-col gap-1.5 shadow-sm z-20"
      >
        <svg
          class="w-5 h-5 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21 12V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h14a2 2 0 002-2v-5zm-7 0a1 1 0 100 2 1 1 0 000-2z"
          ></path>
        </svg>
        <p class="text-white text-[11px] lg:text-xs font-semibold">
          Forward your bank alerts — transactions captured automatically.
        </p>
      </div>

      <!-- Mint card — top right -->
      <div
        class="hidden md:flex absolute top-[5%] right-0 lg:-right-4 w-48 lg:w-52 p-3 lg:p-4 bg-card-mint rounded-2xl flex-col gap-1.5 shadow-sm z-20"
      >
        <svg
          class="w-5 h-5 text-black"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
          ></path>
        </svg>
        <h3 class="text-black text-sm lg:text-base font-medium">
          Pidgin Nudges
        </h3>
        <p class="text-black text-[11px] lg:text-xs">
          Get alerts like ‘Oga, you don spend too much on snacks o!’ in Pidgin
          or English.
        </p>
      </div>

      <!-- User pill — bottom right -->
      <div
        class="hidden lg:flex absolute bottom-[15%] right-[2%] bg-white rounded-full pl-2.5 pr-4 py-1.5 items-center gap-2 shadow-md z-20"
      >
        <div class="flex -space-x-2">
          <Image
            src={avatar1}
            alt=""
            class="w-7 h-7 rounded-full border-2 border-white object-cover"
          />
          <Image
            src={avatar2}
            alt=""
            class="w-7 h-7 rounded-full border-2 border-white object-cover"
          />
          <Image
            src={avatar3}
            alt=""
            class="w-7 h-7 rounded-full border-2 border-white object-cover"
          />
        </div>
        <div class="text-left">
          <div class="text-black text-sm font-semibold leading-none">
            Coming Soon
          </div>
          <div class="text-text-muted text-[10px] mt-0.5">
            Join the Waitlist
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
