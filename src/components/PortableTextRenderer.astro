---
import { PortableText } from "astro-portabletext";
import { urlFor } from "../lib/sanity";
import { createHighlighter } from "shiki";

interface Props {
  body: any[];
}

const { body } = Astro.props;

// Shiki highlighter for code blocks
const shikiLangs = ["javascript", "typescript", "python", "bash", "json", "html", "css", "sql", "dart", "kotlin", "swift", "plaintext"];
const highlighter = await createHighlighter({
  themes: ["github-dark"],
  langs: shikiLangs,
});

function highlightCode(code: string, lang: string): string {
  const resolved = shikiLangs.includes(lang) ? lang : "plaintext";
  return highlighter.codeToHtml(code, { lang: resolved, theme: "github-dark" });
}

// Helper to extract video embed URL
function getEmbedUrl(url: string): string | null {
  const ytMatch = url.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
  );
  if (ytMatch) return `https://www.youtube-nocookie.com/embed/${ytMatch[1]}`;
  const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
  if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
  return null;
}

// Render children text with inline marks
function renderChildren(children: any[]): string {
  if (!children) return "";
  return children
    .map((child: any) => {
      let text = child.text || "";
      if (child.marks?.includes("strong")) text = `<strong>${text}</strong>`;
      if (child.marks?.includes("em")) text = `<em>${text}</em>`;
      if (child.marks?.includes("code")) text = `<code>${text}</code>`;
      if (child.marks?.includes("underline")) text = `<u>${text}</u>`;
      if (child.marks?.includes("strike-through")) text = `<s>${text}</s>`;
      // Handle link annotations
      const linkMark = child.marks?.find((m: string) => m !== "strong" && m !== "em" && m !== "code" && m !== "underline" && m !== "strike-through");
      if (linkMark) {
        const markDef = child._markDefs?.find((d: any) => d._key === linkMark);
        // Note: markDefs are at block level, handled below
      }
      return text;
    })
    .join("");
}

// Render a block's children with link support
function renderBlockChildren(block: any): string {
  if (!block.children) return "";
  return block.children
    .map((child: any) => {
      let text = child.text || "";
      if (child.marks?.includes("strong")) text = `<strong>${text}</strong>`;
      if (child.marks?.includes("em")) text = `<em>${text}</em>`;
      if (child.marks?.includes("code")) text = `<code>${text}</code>`;
      if (child.marks?.includes("underline")) text = `<u>${text}</u>`;
      if (child.marks?.includes("strike-through")) text = `<s>${text}</s>`;
      // Handle link marks
      for (const mark of child.marks || []) {
        if (["strong", "em", "code", "underline", "strike-through"].includes(mark)) continue;
        const def = block.markDefs?.find((d: any) => d._key === mark);
        if (def?._type === "link") {
          const target = def.blank ? ' target="_blank" rel="noopener noreferrer"' : "";
          text = `<a href="${def.href}"${target}>${text}</a>`;
        }
      }
      return text;
    })
    .join("");
}
---

{(body || []).map((block: any) => {
  // ── Heading blocks with TOC IDs ──
  if (block._type === "block" && block.style === "h2") {
    return <h2 id={block._key} set:html={renderBlockChildren(block)} />;
  }
  if (block._type === "block" && block.style === "h3") {
    return <h3 id={block._key} set:html={renderBlockChildren(block)} />;
  }
  if (block._type === "block" && block.style === "h4") {
    return <h4 id={block._key} set:html={renderBlockChildren(block)} />;
  }

  // ── Blockquote ──
  if (block._type === "block" && block.style === "blockquote") {
    return <blockquote set:html={renderBlockChildren(block)} />;
  }

  // ── Code Block ──
  if (block._type === "codeBlock") {
    const highlighted = highlightCode(block.code || "", block.language || "plaintext");
    return (
      <div class="code-block">
        {(block.language || block.filename) && (
          <div class="code-block-header">
            <span>{block.filename || ""}</span>
            <span>{block.language || ""}</span>
          </div>
        )}
        <Fragment set:html={highlighted} />
      </div>
    );
  }

  // ── Callout ──
  if (block._type === "callout") {
    const calloutType = block.type || "info";
    const icons = {
      info: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>`,
      warning: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>`,
      tip: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>`,
      note: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>`,
    };
    return (
      <div class={`callout callout-${calloutType}`}>
        <svg class="callout-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[calloutType as keyof typeof icons] || icons.info} />
        <div>{block.text}</div>
      </div>
    );
  }

  // ── Video Embed ──
  if (block._type === "videoEmbed") {
    const embedUrl = getEmbedUrl(block.url || "");
    if (!embedUrl) return null;
    return (
      <div class="video-embed">
        <iframe
          src={embedUrl}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
          title={block.caption || "Embedded video"}
        />
        {block.caption && <div class="video-caption">{block.caption}</div>}
      </div>
    );
  }

  // ── Image ──
  if (block._type === "image") {
    const imgUrl = urlFor(block)?.width(960).url();
    if (!imgUrl) return null;
    return (
      <figure>
        <img src={imgUrl} alt={block.alt || ""} loading="lazy" />
        {block.caption && <figcaption>{block.caption}</figcaption>}
      </figure>
    );
  }

  // ── Default: PortableText for paragraphs, lists ──
  return <PortableText value={[block]} />;
})}
