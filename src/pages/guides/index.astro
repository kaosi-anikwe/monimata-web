---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getPosts, urlFor } from "../../lib/sanity";

const posts = await getPosts("guide");
---

<BaseLayout
  title="Guides — MoniMata"
  description="Step-by-step guides to help you master budgeting, saving, and managing your money with MoniMata."
>
  <Header />
  <div class="min-h-screen bg-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-12 sm:py-16">
      <!-- Header -->
      <div class="max-w-2xl mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm text-text-body hover:text-primary-dark transition mb-6"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Home
        </a>
        <h1
          class="text-text-heading text-3xl sm:text-4xl lg:text-5xl font-bold"
        >
          Guides
        </h1>
        <p class="mt-4 text-text-body text-lg">
          Step-by-step guides to help you master budgeting, saving, and managing
          your money with MoniMata.
        </p>
      </div>

      {
        posts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
            {posts.map((post: any) => {
              const imgUrl = post.mainImage
                ? urlFor(post.mainImage)?.width(600).height(340).url()
                : null;
              const date = new Date(post.publishedAt).toLocaleDateString(
                "en-NG",
                {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                },
              );
              return (
                <a
                  href={`/guides/${post.slug}`}
                  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow"
                >
                  {imgUrl ? (
                    <div class="aspect-video overflow-hidden">
                      <img
                        src={imgUrl}
                        alt={post.mainImage?.alt || post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                  ) : (
                    <div class="aspect-video bg-primary-darker/5 flex items-center justify-center">
                      <img
                        src="/images/logo.png"
                        alt=""
                        class="w-12 opacity-20"
                      />
                    </div>
                  )}
                  <div class="p-5 sm:p-6">
                    {post.tags?.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {post.tags.slice(0, 3).map((tag: string) => (
                          <span class="text-xs font-medium text-primary-dark bg-accent/10 rounded-full px-2.5 py-0.5">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <h2 class="text-text-heading text-lg font-semibold leading-snug group-hover:text-primary-dark transition-colors">
                      {post.title}
                    </h2>
                    {post.excerpt && (
                      <p class="mt-2 text-text-body text-sm line-clamp-2">
                        {post.excerpt}
                      </p>
                    )}
                    <div class="mt-4 flex items-center gap-3 text-xs text-text-muted">
                      {post.author && <span>{post.author.name}</span>}
                      {post.author && <span>·</span>}
                      <time datetime={post.publishedAt}>{date}</time>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-20">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-darker/5 flex items-center justify-center">
              <svg
                class="w-8 h-8 text-text-muted"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
                />
              </svg>
            </div>
            <p class="text-text-body text-lg font-medium">No guides yet</p>
            <p class="mt-1 text-text-muted text-sm">
              Check back soon for new content.
            </p>
          </div>
        )
      }
    </div>
  </div>
  <Footer />
</BaseLayout>
