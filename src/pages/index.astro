---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Stats from "../components/Stats.astro";
import WhyMonimata from "../components/WhyMonimata.astro";
import Features from "../components/Features.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Gamification from "../components/Gamification.astro";
import FAQ from "../components/FAQ.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout ogImage="/og/home.png">
  <Header />
  <main id="main-content">
    <Hero />
    <Stats />
    <WhyMonimata />
    <Features />
    <HowItWorks />
    <Gamification />
    <FAQ />
    <CTA />
  </main>
  <Footer />
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          name: "MoniMata",
          url: "https://monimata.ng",
          logo: "https://monimata.ng/images/logo-full.svg",
          description: "Zero-based budgeting app built for Nigerians.",
        },
        {
          "@type": "WebSite",
          name: "MoniMata",
          url: "https://monimata.ng",
        },
      ],
    })}
  />
</BaseLayout>
