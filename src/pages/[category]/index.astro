---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import logoPlaceholder from "../../assets/images/logo.png";
import { getCategories, getPosts, urlFor } from "../../lib/sanity";

interface Category {
  name: string;
  slug: string;
  showInHeader: boolean;
}

export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map((c: any) => ({
    params: { category: c.slug },
    props: { category: c },
  }));
}

const category: Category = (Astro.props as any).category;
const categorySlug = category.slug;
const posts = await getPosts(categorySlug);
---

<BaseLayout
  title={`${category.name} — MoniMata`}
  description={`${category.name} posts from MoniMata.`}
  ogImage={`/og/${category.slug}.png`}
>
  <Header />
  <main id="main-content" class="min-h-screen bg-bg">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-12 sm:py-16">
      <!-- Header -->
      <div class="max-w-2xl mb-12">
        <a
          href="/"
          class="inline-flex items-center gap-1.5 text-sm text-text-body hover:text-primary-dark transition mb-6"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 19l-7-7 7-7"></path>
          </svg>
          Home
        </a>
        <h1
          class="text-text-heading text-3xl sm:text-4xl lg:text-5xl font-bold"
        >
          {category.name}
        </h1>
      </div>

      {
        posts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
            {posts.map((post: any) => {
              const imgUrl = post.mainImage
                ? urlFor(post.mainImage)?.width(600).height(340).url()
                : null;
              const date = new Date(post.publishedAt).toLocaleDateString(
                "en-NG",
                {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                },
              );
              return (
                <a
                  href={`/${categorySlug}/${post.slug}`}
                  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow"
                >
                  {imgUrl ? (
                    <div class="aspect-video overflow-hidden">
                      <img
                        src={imgUrl}
                        alt={post.mainImage?.alt || post.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                  ) : (
                    <div class="aspect-video bg-primary-darker/5 flex items-center justify-center">
                      <Image
                        src={logoPlaceholder}
                        alt="MoniMata logo placeholder"
                        class="w-12 opacity-20"
                      />
                    </div>
                  )}
                  <div class="p-5 sm:p-6">
                    {post.tags?.length > 0 && (
                      <div class="flex flex-wrap gap-1.5 mb-3">
                        {post.tags.slice(0, 3).map((tag: string) => (
                          <span class="text-xs font-medium text-primary-dark bg-accent/10 rounded-full px-2.5 py-0.5">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                    <h2 class="text-text-heading text-lg font-semibold leading-snug group-hover:text-primary-dark transition-colors">
                      {post.title}
                    </h2>
                    {post.excerpt && (
                      <p class="mt-2 text-text-body text-sm line-clamp-2">
                        {post.excerpt}
                      </p>
                    )}
                    <div class="mt-4 flex items-center gap-3 text-xs text-text-muted">
                      {post.author && <span>{post.author.name}</span>}
                      {post.author && <span>·</span>}
                      <time datetime={post.publishedAt}>{date}</time>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="text-center py-20">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-darker/5 flex items-center justify-center">
              <svg
                class="w-8 h-8 text-text-muted"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"
                />
              </svg>
            </div>
            <p class="text-text-body text-lg font-medium">
              No {category.name.toLowerCase()} posts yet
            </p>
            <p class="mt-1 text-text-muted text-sm">
              Check back soon for new content.
            </p>
          </div>
        )
      }
    </div>
  </main>
  <Footer />
</BaseLayout>
