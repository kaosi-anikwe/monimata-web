---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found — MoniMata" description="The page you're looking for doesn't exist.">
  <div class="min-h-screen bg-bg flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <div class="text-[8rem] sm:text-[10rem] font-bold leading-none text-primary-darker/10 select-none">
        404
      </div>
      <h1 class="text-text-heading text-2xl sm:text-3xl font-bold -mt-6">
        Page not found
      </h1>
      <p class="mt-3 text-text-body text-base leading-relaxed">
        The page you're looking for doesn't exist or has been moved. Let's get you back on track.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center justify-center bg-primary-dark text-bg rounded-xl px-6 py-3 text-sm font-semibold hover:opacity-90 transition"
        >
          Back to Home
        </a>
        <a
          href="/blog"
          class="inline-flex items-center justify-center border border-primary-darker/20 text-text-heading rounded-xl px-6 py-3 text-sm font-semibold hover:bg-primary-darker/5 transition"
        >
          Read the Blog
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
